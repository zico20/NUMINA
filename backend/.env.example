# Required — never commit the real key
OPENAI_API_KEY=sk-...

# Server
PORT=5000

# CORS — comma-separated list, e.g. "http://localhost:8080,https://yourapp.com"
CORS_ORIGINS=*

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# Optional: pin the model (gpt-4o is recommended for vision)
OPENAI_MODEL=gpt-4o
